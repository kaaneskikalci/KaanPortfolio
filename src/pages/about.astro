---
import { Image } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE, SKILLS } from '../consts';
import portrait from '../assets/placeholders/portrait.svg';
---

<BaseLayout title="About">
  <div class="container">
    <h1 class="section-heading">About</h1>

    <div class="about-grid">
      <div class="about-photo">
        <Image src={portrait} alt={`Portrait of ${SITE.name}`} width={480} />
      </div>

      <div class="about-bio">
        <!-- Replace this with your real introduction. Keep it short and human:
             who you are, what you make, and what you're looking for. -->
        <p>
        <strong> KAAN ESKIKALCI </strong>
        </p>
        <p>
          I graduated from the Digital Game Design program this year. I am
passionately committed to game design and aims to
further develop myself particularly in the field of game
development. I am an individual who consistently focuses
on self-improvement and generating creative ideas in the
areas that interest me. I have full confidence in my ability
to contribute to my team and company at the highest
level.
        </p>
        <p>
          <a class="button" href="/contact">Get in touch</a>
        </p>
      </div>
    </div>

    <h2 class="skills-heading">Skills</h2>
    <div class="skills">
      {
        SKILLS.map((group) => (
          <div class="skill-group">
            <h3>{group.group}</h3>
            <ul>
              {group.items.map((item) => (
                <li class="tag">{item}</li>
              ))}
            </ul>
          </div>
        ))
      }
    </div>
  </div>
</BaseLayout>

<style>
  .about-grid {
    display: grid;
    grid-template-columns: 280px 1fr;
    gap: var(--space-5);
    align-items: start;
    margin-bottom: var(--space-6);
  }
  .about-photo :global(img) {
    width: 100%;
    height: auto;
    border-radius: var(--radius);
    border: 1px solid var(--border);
  }
  .about-bio p {
    margin-bottom: var(--space-3);
  }
  .skills-heading {
    margin-bottom: var(--space-4);
  }
  .skills {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: var(--space-4);
  }
  .skill-group h3 {
    margin-bottom: var(--space-3);
    color: var(--muted);
    font-size: 0.95rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  .skill-group ul {
    list-style: none;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }

  @media (max-width: 640px) {
    .about-grid {
      grid-template-columns: 1fr;
    }
    .about-photo {
      max-width: 240px;
    }
  }
</style>
