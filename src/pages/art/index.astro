---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ProjectCard from '../../components/ProjectCard.astro';

// Sorted alphabetically by title.
const projects = (await getCollection('art')).sort((a, b) =>
  a.data.title.localeCompare(b.data.title)
);
---

<BaseLayout
  title="Art & Game Design"
  description="3D environments, level design, and visual work by Kaan Eskikalci."
>
  <div class="container">
    <h1 class="section-heading">Art &amp; Game Design</h1>
    <p class="section-intro">
      Game Design, 3D Design, Level Design etc.
    </p>

    {
      projects.length > 0 ? (
        <div class="project-grid">
          {projects.map((p) => (
            <ProjectCard
              href={`/art/${p.id}`}
              cover={p.data.cover}
              title={p.data.title}
              summary={p.data.summary}
              meta={p.data.medium}
              tags={p.data.tools}
            />
          ))}
        </div>
      ) : (
        <p style="color: var(--muted)">Projects coming soon.</p>
      )
    }
  </div>
</BaseLayout>
