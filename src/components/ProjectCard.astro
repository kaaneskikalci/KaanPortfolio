---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  href: string;
  cover: ImageMetadata;
  title: string;
  summary: string;
  meta?: string; // role or medium — small label above the title
  tags?: string[]; // tools/tech, shown as pills
}

const { href, cover, title, summary, meta, tags = [] } = Astro.props;
---

<a class="card" href={href}>
  <div class="card-media">
    <Image
      src={cover}
      alt={`${title} cover image`}
      widths={[400, 800]}
      sizes="(max-width: 640px) 100vw, 360px"
      loading="lazy"
    />
  </div>
  <div class="card-body">
    {meta && <span class="card-meta">{meta}</span>}
    <h3 class="card-title">{title}</h3>
    <p class="card-summary">{summary}</p>
    {
      tags.length > 0 && (
        <ul class="card-tags">
          {tags.slice(0, 4).map((t) => (
            <li class="tag">{t}</li>
          ))}
        </ul>
      )
    }
  </div>
</a>

<style>
  .card {
    display: flex;
    flex-direction: column;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    overflow: hidden;
    color: var(--fg);
    transition: transform var(--transition), border-color var(--transition);
  }

  .card:hover {
    opacity: 1;
    transform: translateY(-4px);
    border-color: var(--accent);
  }

  .card-media {
    aspect-ratio: 16 / 10;
    background: var(--surface-2);
    overflow: hidden;
  }

  .card-media :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 300ms ease;
  }

  .card:hover .card-media :global(img) {
    transform: scale(1.04);
  }

  .card-body {
    padding: var(--space-3);
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .card-meta {
    font-size: 0.78rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--accent);
    font-weight: 600;
  }

  .card-title {
    font-size: 1.15rem;
  }

  .card-summary {
    color: var(--muted);
    font-size: 0.95rem;
  }

  .card-tags {
    list-style: none;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    margin-top: var(--space-1);
  }
</style>
