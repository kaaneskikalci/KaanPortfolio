---
// Embeds an interactive Sketchfab 3D model. Pass the model id (the string in a
// Sketchfab URL after /models/ or /3d-models/...-<id>). Lazy-loaded so it never
// slows the initial page render.
interface Props {
  id: string;
  title?: string;
}
const { id, title = '3D model' } = Astro.props;
---

<div class="sketchfab">
  <iframe
    title={title}
    src={`https://sketchfab.com/models/${id}/embed?ui_theme=dark`}
    allow="autoplay; fullscreen; xr-spatial-tracking"
    allowfullscreen
    loading="lazy"
  ></iframe>
</div>

<style>
  .sketchfab {
    aspect-ratio: 16 / 10;
    border-radius: var(--radius);
    overflow: hidden;
    border: 1px solid var(--border);
    background: var(--surface-2);
  }
  .sketchfab iframe {
    width: 100%;
    height: 100%;
    border: 0;
  }
</style>
